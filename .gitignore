# Dependencies
node_modules/

# Build output
dist/

# Dotfiles/dotfolders are local-only by default. Allowlist exceptions only when
# the project explicitly decides they belong in Git.
.*
!/.gitignore

# Markdown files are ignored by default so ad-hoc plans/notes are not pushed.
# Explicitly allow root release/readme docs and versioned examples.
*.md
!README.md
!README.*.md
!CHANGELOG.md
!CHANGELOG.*.md
!examples/
!examples/**/
!examples/*.md
!examples/**/*.md

# Local OpenCode project config. Anchored so it does not match
# src/lib/themes/opencode.json.
/opencode.json

# Bun
bunfig.toml.lock

# Editor/OS leftovers that do not necessarily start with a dot
*.swp
*.swo
*~
Thumbs.db
.loop*
