{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "darkBg": "#0a0a0a",
    "darkPanel": "#0d0d0d",
    "darkElement": "#161616",
    "darkBorderSubtle": "#262626",
    "darkBorder": "#3f3f46",
    "darkBorderActive": "#c11b05",
    "darkRed": "#c11b05",
    "darkRedBright": "#ff4d36",
    "darkRedDeep": "#890f0a",
    "darkText": "#faf8f6",
    "darkMuted": "#8c8c93",
    "darkGreen": "#3fb950",
    "darkAmber": "#fbb03b",
    "darkErr": "#ff453a",
    "darkBlue": "#40a9f6",
    "lightBg": "#faf8f6",
    "lightPanel": "#ffffff",
    "lightElement": "#f4f4f5",
    "lightBorderSubtle": "#e4e4e7",
    "lightBorder": "#d1d5db",
    "lightBorderActive": "#c11b05",
    "lightRed": "#c11b05",
    "lightRedBright": "#a3160a",
    "lightRedDeep": "#890f0a",
    "lightText": "#0a0a0a",
    "lightMuted": "#4a4a4a",
    "lightGreen": "#1a7f37",
    "lightAmber": "#bf8700",
    "lightErr": "#cf222e",
    "lightBlue": "#0969da"
  },
  "theme": {
    "primary": { "dark": "darkRed", "light": "lightRed" },
    "secondary": { "dark": "darkRedBright", "light": "lightRedBright" },
    "accent": { "dark": "darkRedBright", "light": "lightRedDeep" },
    "error": { "dark": "darkErr", "light": "lightErr" },
    "warning": { "dark": "darkAmber", "light": "lightAmber" },
    "success": { "dark": "darkGreen", "light": "lightGreen" },
    "info": { "dark": "darkBlue", "light": "lightBlue" },
    "text": { "dark": "darkText", "light": "lightText" },
    "textMuted": { "dark": "darkMuted", "light": "lightMuted" },
    "background": { "dark": "darkBg", "light": "lightBg" },
    "backgroundPanel": { "dark": "darkPanel", "light": "lightPanel" },
    "backgroundElement": { "dark": "darkElement", "light": "lightElement" },
    "border": { "dark": "darkBorder", "light": "lightBorder" },
    "borderActive": { "dark": "darkBorderActive", "light": "lightBorderActive" },
    "borderSubtle": { "dark": "darkBorderSubtle", "light": "lightBorderSubtle" }
  }
}
